  Future<void> _runSpeedTest() async {
    if (_speedTestRunning) return;

    setState(() => _speedTestRunning = true);

    await _speedTest.startTesting(
      useFastApi: true, // Nonaktifkan Fast API jika bermasalah
      //   downloadTestServer: 'http://speedtest.ftp.otenet.gr/files/test1Mb.db',
      //   uploadTestServer: 'http://speedtest.ftp.otenet.gr/',
      fileSizeInBytes: 100000000, // Kurangi file size (100MB)
      onStarted: () {
        setState(() {
          _downloadProgress = 0;
          _uploadProgress = 0;
        });
      },
      onCompleted: (TestResult download, TestResult upload) {
        print(
          '$TAG onCompleted: Download ${download.transferRate}, Upload ${upload.transferRate}',
        );

        _logger.speed(
          'Complete - DL: ${download.transferRate.toStringAsFixed(2)} Mbps | '
          'UL: ${upload.transferRate.toStringAsFixed(2)} Mbps',
        );
        setState(() {
          _downloadSpeed = download.transferRate;
          _uploadSpeed = upload.transferRate;
          _downloadProgress = 100;
          _uploadProgress = 100;
          _speedUnit = download.unit == SpeedUnit.kbps ? 'Kbps' : 'Mbps';
          _speedTestRunning = false;

          // Simulate ping based on speed
          _ping = _calculateSimulatedPing(download.transferRate);
        });

        _stopIntegratedTest();
        // _completeTestSession();
      },
      onProgress: (double percent, TestResult data) {
        print(
          '$TAG onProgress: ${data.transferRate}, ${data.unit == SpeedUnit.kbps ? 'Kbps' : 'Mbps'}, ${data.type == TestType.download ? 'Download' : 'Upload'}',
        );

        final type = data.type == TestType.download ? 'DOWNLOAD' : 'UPLOAD';
        // Log setiap 20% untuk tidak spam console
        if (percent % 20 == 0 || percent == 100) {
          _logger.speed(
            '$type: ${percent.toStringAsFixed(0)}% - '
            '${data.transferRate.toStringAsFixed(2)} Mbps',
          );
        }
        setState(() {
          _speedUnit = data.unit == SpeedUnit.kbps ? 'Kbps' : 'Mbps';
          if (data.type == TestType.download) {
            _downloadSpeed = data.transferRate;
            _downloadProgress = percent;
          } else {
            _uploadSpeed = data.transferRate;
            _uploadProgress = percent;
          }
        });
      },
      onDefaultServerSelectionDone: (client) {
        print(
          "$TAG Default server selected: IP ${client?.ip} - ISP ${client?.isp} - LOCATION ${client?.location?.country ?? ''} - ASN ${client?.asn}",
        );
        _logger.speed(
          'Default server selected: '
          'IP: ${client?.ip ?? 'Unknown'} - '
          'ISP: ${client?.isp ?? 'Unknown'} - '
          '${client?.location?.country ?? 'Unknown'}',
        );
        setState(() {
          _serverIp = client?.ip;
          _serverIsp = client?.isp;
          _serverLocation =
              "${client?.location?.city ?? ''}, ${client?.location!.country}";
        });
      },
      onDownloadComplete: (TestResult data) {
        _logger.speed(
          'Download completed: ${data.transferRate.toStringAsFixed(2)} Mbps',
        );
      },
      onUploadComplete: (TestResult data) {
        _logger.speed(
          'Upload completed: ${data.transferRate.toStringAsFixed(2)} Mbps',
        );
      },
      onError: (errorMessage, speedTestError) {
        _logger.error('Speed test error: $errorMessage');
        setState(() => _speedTestRunning = false);
      },
    );
  }

  double _calculateSimulatedPing(double speed) {
    if (speed > 100) return 5.0;
    if (speed > 50) return 15.0;
    if (speed > 20) return 30.0;
    if (speed > 5) return 60.0;
    return 120.0;
  }

  void _completeTestSession() {
    setState(() {
      _isTesting = false;
      _isMonitoring = false;
      _speedTestRunning = false;
    });

    _telephonyTimer?.cancel();
    _sessionTimer?.cancel();
    _speedTest.cancelTest();

    // Save session results
    _saveTestSession();
    _submitCapture();
  }

  Future<void> _submitCapture() async {
    if (_deviceInfo == null || _simInfo == null) {
      debugPrint('[Dashboard] Cannot submit: deviceInfo or simInfo is null');
      return;
    }

    final result = await _captureService.submitFullCapture(
      deviceInfo: _deviceInfo!,
      simInfo: _simInfo!,
      cellularInfo: _cellularInfo, // + BARU
      sessionStartedAt: _sessionStartedAt ?? DateTime.now(),
      sessionEndedAt: DateTime.now(),
      positions: List<Position>.from(positions),
      telemetryHistory: List<TelephonySnapshot>.from(_telemetryHistory),
      downloadSpeed: _downloadSpeed,
      uploadSpeed: _uploadSpeed,
      ping: _ping,
      speedUnit: _speedUnit, // + BARU
      servingCell: _servingCell,
      neighbourCells: List<NeighbourCell>.from(_neighbourCells),
    );

    switch (result) {
      case CaptureSuccess(:final response):
        _showSnackBar(
          '✅ Capture saved (ID: ${response.captureId})',
          Colors.green,
        );

      case CaptureFailure(:final error):
        _showSnackBar('❌ Upload failed: $error', Colors.red);
    }
  }

  void _showSnackBar(String message, Color color) {
    if (!mounted) return;
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text(message),
        backgroundColor: color,
        behavior: SnackBarBehavior.floating,
        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),
        duration: const Duration(seconds: 4),
      ),
    );
  }

  void _saveTestSession() {
    final session = TestSession(
      timestamp: DateTime.now(),
      telemetryData: List.from(_telemetryHistory),
      downloadSpeed: _downloadSpeed,
      uploadSpeed: _uploadSpeed,
      ping: _ping,
      networkType: _networkType,
      operatorName: _operatorName,
    );

    setState(() {
      _testSessions.insert(0, session);
      if (_testSessions.length > 5) {
        _testSessions.removeLast();
      }
    });

    // Show summary
    _showSessionSummary(session);
  }

