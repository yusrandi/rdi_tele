  void startTracking() {
    _logger.location('Starting GPS tracking...');

    positionStream =
        Geolocator.getPositionStream(
          locationSettings: const LocationSettings(
            accuracy: LocationAccuracy.high,
            distanceFilter: 10, // update tiap pindah 10 meter
          ),
        ).listen((Position position) {
          print('$TAG : Lat: ${position.latitude}, Lng: ${position.longitude}');

          _logger.location(
            'Lat: ${position.latitude.toStringAsFixed(5)}, '
            'Lng: ${position.longitude.toStringAsFixed(5)}, '
            'Accuracy: ${position.accuracy.toStringAsFixed(2)}m, '
            'Altitude: ${position.altitude.toStringAsFixed(2)}m, '
            'Speed: ${position.speed.toStringAsFixed(2)}m/s, ',
          );

          positions.add(position);
        });
  }

  void stopTracking() {
    _logger.location('GPS tracking stopped');
    positionStream?.cancel();
  }

