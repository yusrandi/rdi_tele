  void _stopIntegratedTest() {
    if (!_isTesting) return;

    _logger.session('Stopping test session');
    setState(() {
      _isTesting = false;
      _isMonitoring = false;
      _speedTestRunning = false;
    });

    _telephonyTimer?.cancel();
    _sessionTimer?.cancel();
    _speedTest.cancelTest();
    stopTracking();

    _completeTestSession();
