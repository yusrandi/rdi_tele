  String _calculateAverageRssi() {
    if (_telemetryHistory.isEmpty) return '0';
    final sum = _telemetryHistory.map((e) => e.rssi).reduce((a, b) => a + b);
    return (sum / _telemetryHistory.length).toStringAsFixed(0);
  }

  String _calculateAverage(int Function(dynamic) selector) {
    if (_telemetryHistory.isEmpty) return '0';
    final sum = _telemetryHistory.map(selector).reduce((a, b) => a + b);
    return (sum / _telemetryHistory.length).toStringAsFixed(0);
  }

  String _calculateMedian(int Function(dynamic) selector) {
    if (_telemetryHistory.isEmpty) return '0';

    final values = _telemetryHistory.map(selector).toList()..sort();
    final length = values.length;
    final middleIndex = length ~/ 2;

    if (length % 2 == 1) {
      return values[middleIndex].toStringAsFixed(0);
    }

    final median = (values[middleIndex - 1] + values[middleIndex]) / 2;
    return median.toStringAsFixed(0);
  }

  String _calculateMode(int Function(dynamic) selector) {
    if (_telemetryHistory.isEmpty) return '0';

    final values = _telemetryHistory.map(selector).toList();
    print('SELECTOR items ${values.toString()} ');

    // Hitung frekuensi setiap nilai
    final frequencyMap = <int, int>{};
    for (var value in values) {
      frequencyMap[value] = (frequencyMap[value] ?? 0) + 1;
    }

    // Cari frekuensi maksimal
    int maxFrequency = frequencyMap.values.reduce((a, b) => a > b ? a : b);

    // Ambil semua nilai dengan frekuensi maksimal
    final modes =
        frequencyMap.entries
            .where((entry) => entry.value == maxFrequency)
            .map((entry) => entry.key)
            .toList()
          ..sort();

    // Return nilai terkecil jika ada beberapa modus
    return modes.first.toStringAsFixed(0);
  }

