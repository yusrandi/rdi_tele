  Future<void> _updateTelemetryData() async {
    if (!_isMonitoring || !Platform.isAndroid) return;

    try {
      final tmData = await _rdiTelePlugin.getTM();
      final neighbourCells = await _rdiTelePlugin.getNeighbourCells();
      final servingCell = await _rdiTelePlugin.getServingCell();
      final cellularInfo = await _rdiTelePlugin.getCellularInfo();
      final simInfo = await _rdiTelePlugin.getSimInfo();

      final now = DateTime.now();

      final snapshot = TelephonySnapshot(
        timestamp: now,
        rsrp: tmData[UseTMConst.rsrp] as int? ?? 0,
        rsrq: tmData[UseTMConst.rsrq] as int? ?? 0,
        rssi: tmData[UseTMConst.rssi] as int? ?? 0,
        rssnr: tmData[UseTMConst.rssnr] as int? ?? 0,
        cellId: tmData[UseTMConst.cellid] as int? ?? 0,
        dbm: tmData[UseTMConst.dbm] as int? ?? 0,
        level: tmData[UseTMConst.level] as int? ?? 0,
        ta: tmData[UseTMConst.ta] as int?,
        cqi: tmData[UseTMConst.cqi] as int?,
        simInfo: SimInfo.fromMap(Map<String, dynamic>.from(simInfo)),
        deviceInfo: _deviceInfo!,
        servingCell: ServingCell.fromMap(
          Map<String, dynamic>.from(servingCell),
        ),
        cellularInfo: CellularInfo.fromMap(
          Map<String, dynamic>.from(cellularInfo),
        ),
        neighbourCells: neighbourCells
            .map((cell) => NeighbourCell.fromMap(cell))
            .toList(),
      );

      final servMap = ServingCell.fromMap(
        Map<String, dynamic>.from(servingCell),
      );

      _logger.telephony(
        'RSRP: ${snapshot.rsrp} dBm | '
        'RSRQ: ${snapshot.rsrq} dB | '
        'RSSI: ${snapshot.rssi} dBm | '
        'Cell: ${snapshot.cellId}',
      );
      _logger.servingCell(
        'MCC: ${servMap.mcc} | MNC: ${servMap.mnc} | '
        'CID: ${servMap.ci} | PCI: ${servMap.pci} | RSRP: ${servMap.rsrp} dBm | RSRQ: ${servMap.rsrq} dB | RSSI: ${servMap.rssi} dBm ',
      );

      setState(() {
        _currentRsrp = snapshot.rsrp;
        _currentRsrq = snapshot.rsrq;
        _currentRssi = snapshot.rssi;
        _currentSNR = snapshot.rssnr;
        _currentCellId = snapshot.cellId;
        _currentSignal = "${snapshot.dbm} dBm";

        _telemetryHistory.insert(0, snapshot);

        _servingCell = servMap;

        _neighbourCells = neighbourCells
            .map((cell) => NeighbourCell.fromMap(cell))
            .toList();

        _cellularInfo = CellularInfo.fromMap(
          Map<String, dynamic>.from(cellularInfo),
        );
        _simInfo = SimInfo.fromMap(Map<String, dynamic>.from(simInfo));

        // Keep last 30 snapshots
        if (_telemetryHistory.length > 30) {
          _telemetryHistory.removeLast();
        }
      });
    } catch (e) {
      print("[$TAG] Telemetry error: $e");
      _logger.error('Telemetry update failed: $e');
    }
  }

